# Email Configuration for Contact Form
# All emails will be sent to this address
CONTACT_EMAIL=krayonova@gmail.com

# Gmail SMTP Credentials (Using Nodemailer)
# IMPORTANT: Use Gmail App Password, NOT your regular Gmail password
# To generate an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords: https://myaccount.google.com/apppasswords
# 4. Generate a 16-character password
# 5. Paste it below (without spaces)

EMAIL_USER=krayonova@gmail.com
EMAIL_PASS=your_16_character_app_password_here

# Environment
NODE_ENV=production
